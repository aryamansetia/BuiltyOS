{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend Dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"backend",
				"run",
				"dev"
			],
			"isBackground": true
		},
		{
			"label": "Run Frontend Dev",
			"type": "shell",
			"command": "npm",
			"args": [
				"--prefix",
				"frontend",
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1",
				"--port",
				"5173"
			],
			"isBackground": true
		}
	]
}